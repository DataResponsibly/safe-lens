FROM node:20-alpine

WORKDIR /app

# Install dependencies once during image build so the running container does
# not need an `npm install` step at startup. Source files are bind-mounted at
# runtime (see dev/docker-compose.yml); node_modules lives in a named volume
# so the bind mount does not shadow it.
COPY client/package.json client/package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
